# Kit (ConvertKit) — never commit real values
# KIT_FORM_ID: from embed URL app.kit.com/forms/{ID}/subscriptions (e.g. 4969496)
# Required for /api/subscribe (uses Kit native form POST → sends confirmation email)
# KIT_API_KEY / KIT_BROADCAST_API_KEY: only for /api/latest-broadcast (v4)
KIT_FORM_ID=
KIT_API_KEY=
KIT_BROADCAST_API_KEY=

# Server-only Kit key for reading public broadcasts (GET /api/latest-broadcast). Do not expose to the browser.
KIT_BROADCAST_API_KEY=

# Local `vercel dev`: copy the line above into `.env.local` (preferred) or `.env` (both gitignored).
# If `/api/latest-broadcast` still returns 503 locally, the CLI sometimes omits `.env.local` for `/api/*`—use `.env` or run:
#   KIT_BROADCAST_API_KEY=... npx vercel dev --listen 3000 --yes
