{
  "name": "mrtylerwhite-static",
  "private": true,
  "description": "Static site — local dev uses live-server for auto-reload",
  "scripts": {
    "dev": "live-server . --port=4321 --host=127.0.0.1 --open=/",
    "dev:api": "vercel dev --listen 127.0.0.1:4321",
    "serve": "npx serve@latest . -l 4321",
    "build:css": "node scripts/build-css-bundles.mjs",
    "strip:css": "node scripts/strip-dead-css-links.mjs",
    "apply:css-performance": "node scripts/strip-dead-css-links.mjs && node scripts/build-css-bundles.mjs"
  },
  "devDependencies": {
    "live-server": "^1.2.2",
    "node-html-parser": "^8.0.3"
  }
}
